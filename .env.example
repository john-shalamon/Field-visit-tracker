# Supabase Configuration
# Get these values from your Supabase project settings > API

# Your Supabase project URL
# Example: https://myproject.supabase.co
EXPO_PUBLIC_SUPABASE_URL=https://your-project-url.supabase.co

# Your Supabase anonymous/public API key
# Found in Settings > API > Project API keys
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Supabase service role key (only for backend use, never expose in app)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
